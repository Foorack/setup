{
  "editor.inlineSuggest.enabled": true,
  "editor.formatOnSave": true,
  "explorer.confirmPasteNative": false,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "workbench.startupEditor": "none",
  "terminal.integrated.scrollback": 100000,
  "security.workspace.trust.untrustedFiles": "open",

  // START: Copilot
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": true,
    "scminput": false,
  },
  "chat.tools.global.autoApprove": true,
  "chat.tools.terminal.autoApprove": {
    "cat": true,
    "cd": true,
    "date": true,
    "echo": true,
    "find": true,
    "grep": true,
    "head": true,
    "less": true,
    "ls": true,
    "man": true,
    "mkdir": true,
    "pwd": true,
    "sed": true,
    "tail": true,
    "uname": true,
    "wc": true,
    "whoami": true,
    "git status": true,
    "git log": true,
    "git diff": true,
    "git checkout": true,
    "git branch --show-current": true,
    "git show": true,
    "git add": true,
    "git commit": true,
    "cargo": true,
    "docker compose": true,
    "tofu plan": true,
    "tofu fmt": true,
    "tofu validate": true,
  },
  "chat.agent.thinking.terminalTools": true,
  "chat.agent.maxRequests": 300,
  "chat.editing.confirmEditRequestRemoval": false,
  "chat.instructionsFilesLocations": {
    "AGENTS.md": true,
  },
  "chat.tools.terminal.outputLocation": "terminal",
  "chat.viewSessions.orientation": "stacked",
  "chat.tips.enabled": false,
  // END: Copilot

  // START: Languages
  "rust-analyzer.lens.implementations.enable": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "[typescript][javascript][jsonc][css][html][json][dockercompose][typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode",
  },
  "[dockercompose]": {
    "editor.defaultFormatter": "ms-azuretools.vscode-containers",
  },
  // END: Languages

  // START: Theme
  "workbench.colorTheme": "Coderack Theme",
  "workbench.iconTheme": "catppuccin-latte",
  // END: Theme

  // START: Git
  "diffEditor.ignoreTrimWhitespace": false,
  "git.autofetch": true,
  "git.blame.editorDecoration.enabled": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "git.openRepositoryInParentFolders": "never",
  // END: Git
}
